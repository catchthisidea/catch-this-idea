# ── Catch This Idea — Environment Variables ──────────────────
# Copia este ficheiro para .env e preenche com as tuas credenciais.
# NUNCA commitas o ficheiro .env.

# ── Anthropic (Claude) ───────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ─────────────────────────────────────────────────
# https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# https://dashboard.stripe.com/webhooks → selecciona o endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email transaccional) ─────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Site ─────────────────────────────────────────────────────
# URL canónico (sem barra final) — usado nos redirects do Stripe
SITE_URL=https://catchthisidea.com
